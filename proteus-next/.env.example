# Required
NVIDIA_NIM_API_KEY=nvapi-your-key-here

# Auth (required for production)
AUTH_SECRET=generate-with-npx-auth-secret
SMTP_PASS=your-resend-api-key
EMAIL_FROM=PROTEUS <onboarding@resend.dev>

# Vercel only (not needed for local dev)
# Sign up at https://turso.tech for a free libsql database
# DATABASE_URL=libsql://your-db-name-your-org.turso.io
# DATABASE_AUTH_TOKEN=your-auth-token

# E2E test bot (set as GitHub Actions secrets)
TEST_BOT_EMAIL=your-test-bot@example.com
TEST_BOT_PASSWORD=Your!Strong#Password1
